# Copy to .env.local and fill in your actual values. .env.local is git-ignored.

# Supabase (Project Settings -> Data API for URL, API Keys for the two keys below)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Anthropic (console.anthropic.com -> Settings -> API Keys)
ANTHROPIC_API_KEY=

# Google Calendar OAuth (console.cloud.google.com -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
